SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=your-sender@example.com
SMTP_PASSWORD=your-smtp-authorization-code
SMTP_FROM=your-sender@example.com

# AI_web is the only RSS collector. The automation downloads packaged data.
AI_WEB_BASE_URL=https://aiweb-roan.vercel.app
AI_WEB_CRON_SECRET=
AI_WEB_TIMEOUT=60
AI_WEB_DISCOVER_DIRECT_RSS=1
SOURCE_CANDIDATE_LIMIT=10

# Required on every collection run for supplemental search/source discovery.
ARK_SEARCH_API_KEY=
ARK_SEARCH_MODE=responses
ARK_RESPONSES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_SEARCH_MODEL=doubao-seed-2-1-pro-260628
ARK_SEARCH_FALLBACK_MODEL=doubao-seed-2-1-turbo-260628
DOUBAO_SEARCH_RESULT_COUNT=20
DOUBAO_SEARCH_STREAM=1
DOUBAO_SEARCH_TIMEOUT=300
DOUBAO_SEARCH_MAX_RETRIES=1

AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash
