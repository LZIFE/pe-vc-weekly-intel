SMTP_HOST=smtp.163.com
SMTP_PORT=994
SMTP_USER=your_sender@163.com
SMTP_PASSWORD=your_163_authorization_code
SMTP_FROM=your_sender@163.com

# DeepSeek V4 Flash (OpenAI-compatible endpoint for batch intelligence analysis)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://ai.ctaigw.cn/v1
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: replace the public RSSHub instance; defaults to local Docker in CI, public fallback otherwise.
RSSHUB_BASE_URL=http://127.0.0.1:1200

# Optional: keep AI calls bounded. Set BATCH_SIZE / AI_SEARCH_COMPANY_LIMIT for local smoke tests.
AI_HTTP_TIMEOUT=45
AI_SEARCH_COMPANY_LIMIT=0
BATCH_SIZE=8
BATCH_SEARCH_DELAY=2
SEARCH_DAYS=30

# Optional: split large report emails to avoid SMTP server disconnects.
EMAIL_CHUNK_SIZE=25
EMAIL_DELIVERY_MODE=auto
EMAIL_SPLIT_MODE=0