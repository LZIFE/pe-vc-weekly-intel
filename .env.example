SMTP_HOST=smtp.163.com
SMTP_PORT=994
SMTP_USER=your_sender@163.com
SMTP_PASSWORD=your_163_authorization_code
SMTP_FROM=your_sender@163.com

# Doubao is the only search provider.
ARK_SEARCH_API_KEY=
ARK_SEARCH_MODE=responses
ARK_RESPONSES_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_SEARCH_MODEL=doubao-seed-2-1-turbo-260628
DOUBAO_PE_COMPANY_LIMIT=100
DOUBAO_SEARCH_RESULT_COUNT=20
DOUBAO_SEARCH_BATCH_SIZE=20
DOUBAO_SEARCH_WORKERS=2
DOUBAO_SEARCH_STREAM=1
DOUBAO_SEARCH_TIMEOUT=300
DOUBAO_SEARCH_MAX_RETRIES=1

# Agnes handles all non-search reading, analysis, and PDF summaries.
AGNES_API_KEY=
AGNES_BASE_URL=https://apihub.agnes-ai.com/v1
AGNES_MODEL=agnes-2.0-flash
AGNES_MAX_PROMPT_CHARS=48000
AGNES_MAX_OUTPUT_TOKENS=4096

# Optional: replace the public RSSHub instance; defaults to local Docker in CI, public fallback otherwise.
RSSHUB_BASE_URL=http://127.0.0.1:1200

# Optional: keep AI calls bounded. Set BATCH_SIZE / AI_SEARCH_COMPANY_LIMIT for local smoke tests.
AI_HTTP_TIMEOUT=300
SEARCH_DAYS=30

# Optional JSON/JSONL crawler drop file or directory. Multiple paths use the
# platform path separator (`:` on macOS/Linux).
CRAWLER_INPUT=
URL_VERIFY_WORKERS=16

# Optional: split large report emails to avoid SMTP server disconnects.
EMAIL_CHUNK_SIZE=25
EMAIL_DELIVERY_MODE=auto
EMAIL_SPLIT_MODE=0
